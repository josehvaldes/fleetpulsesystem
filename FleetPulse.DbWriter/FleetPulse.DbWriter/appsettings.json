{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "GroupId": "fleetpulse-db-writer",
    "Topic": "gps-pings",
    "HighSpeedCompressionThreshold": 40,
    "HighSpeedCompressionBucketKey": 15
  },
  "ConnectionStrings": {
    "FleetPulseDb": "Host=timescaledb-1;Port=5432;Database=fleetpulse;Username={your_username};Password={your_password}"
  }
}
